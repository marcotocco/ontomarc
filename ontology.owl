    <owl:Ontology rdf:about="https://purl.org/ontomarc/onto">
        <owl:versionIRI rdf:resource="https://purl.org/ontomarc/onto/releases/0.0.1"/>
        <terms:creator>Marco Tocco</terms:creator>
        <terms:description xml:lang="en">A minimal test ontology created to verify PURL redirects, hash-based IRIs, and GitHub Pages publication.</terms:description>
        <terms:license rdf:resource="https://creativecommons.org/licenses/by/4.0/"/>
        <terms:title xml:lang="en">Ontomarc Test Ontology</terms:title>
        <vann:preferredNamespacePrefix>ontomarc</vann:preferredNamespacePrefix>
        <vann:preferredNamespaceUri>https://purl.org/ontomarc/onto#</vann:preferredNamespaceUri>
        <rdfs:comment xml:lang="en">This ontology is only a temporary test for checking stable IRIs, PURL redirects, hash-based term IRIs, and static web publication.</rdfs:comment>
        <rdfs:label xml:lang="en">Ontomarc Test Ontology</rdfs:label>
        <owl:versionInfo>0.0.1</owl:versionInfo>
    </owl:Ontology>
    


