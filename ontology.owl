     -->


    


    <!-- https://purl.org/ontomarc/onto#deviceCode -->


    <owl:DatatypeProperty rdf:about="https://purl.org/ontomarc/onto#deviceCode">
        <rdfs:domain rdf:resource="https://purl.org/ontomarc/onto#Device"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment xml:lang="en">A textual identifier for a device.</rdfs:comment>
        <rdfs:label xml:lang="en">device code</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- https://purl.org/ontomarc/onto#numericValue -->


    <owl:DatatypeProperty rdf:about="https://purl.org/ontomarc/onto#numericValue">
        <rdfs:domain rdf:resource="https://purl.org/ontomarc/onto#Measurement"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#decimal"/>
        <rdfs:comment xml:lang="en">The numeric value of a measurement.</rdfs:comment>
        <rdfs:label xml:lang="en">numeric value</rdfs:label>
    </owl:DatatypeProperty>
    


