        <recordsMeasurement rdf:resource="https://purl.org/ontomarc/onto#TestMeasurement01"/>
        <deviceCode>DEV-001</deviceCode>
        <rdfs:label xml:lang="en">Test device 01</rdfs:label>
    </owl:NamedIndividual>
    


    <!-- https://purl.org/ontomarc/onto#TestMeasurement01 -->


    <owl:NamedIndividual rdf:about="https://purl.org/ontomarc/onto#TestMeasurement01">
