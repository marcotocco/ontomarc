        <rdfs:label xml:lang="en">Device</rdfs:label>
    </owl:Class>
    


    <!-- https://purl.org/ontomarc/onto#Measurement -->


    <owl:Class rdf:about="https://purl.org/ontomarc/onto#Measurement">
        <rdfs:comment xml:lang="en">A generic measurement produced by a device.</rdfs:comment>
        <rdfs:label xml:lang="en">Measurement</rdfs:label>
    </owl:Class>
    


