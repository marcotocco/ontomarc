    <!-- https://purl.org/ontomarc/onto#recordsMeasurement -->


    <owl:ObjectProperty rdf:about="https://purl.org/ontomarc/onto#recordsMeasurement">
        <rdfs:domain rdf:resource="https://purl.org/ontomarc/onto#Device"/>
        <rdfs:range rdf:resource="https://purl.org/ontomarc/onto#Measurement"/>
        <rdfs:comment xml:lang="en">Links a device to a measurement it records.</rdfs:comment>
        <rdfs:label xml:lang="en">records measurement</rdfs:label>
    </owl:ObjectProperty>
    


