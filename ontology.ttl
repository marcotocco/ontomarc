@prefix : <https://purl.org/ontomarc/onto#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xml: <http://www.w3.org/XML/1998/namespace> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@base <https://purl.org/ontomarc/onto#> .

<https://purl.org/ontomarc/onto> rdf:type owl:Ontology ;
                                  owl:versionIRI <https://purl.org/ontomarc/onto/releases/0.0.1> ;
                                  <http://purl.org/dc/terms/creator> "Marco Tocco" ;
                                  <http://purl.org/dc/terms/description> "A minimal test ontology created to verify PURL redirects, hash-based IRIs, and GitHub Pages publication."@en ;
                                  <http://purl.org/dc/terms/license> <https://creativecommons.org/licenses/by/4.0/> ;
                                  <http://purl.org/dc/terms/title> "Ontomarc Test Ontology"@en ;
                                  <http://purl.org/vocab/vann/preferredNamespacePrefix> "ontomarc" ;
                                  <http://purl.org/vocab/vann/preferredNamespaceUri> "https://purl.org/ontomarc/onto#" ;
                                  rdfs:comment "This ontology is only a temporary test for checking stable IRIs, PURL redirects, hash-based term IRIs, and static web publication."@en ;
                                  rdfs:label "Ontomarc Test Ontology"@en ;
                                  owl:versionInfo "0.0.1" .

#################################################################
#    Annotation properties
#################################################################

###  http://purl.org/dc/terms/creator
<http://purl.org/dc/terms/creator> rdf:type owl:AnnotationProperty .


###  http://purl.org/dc/terms/description
<http://purl.org/dc/terms/description> rdf:type owl:AnnotationProperty .


###  http://purl.org/dc/terms/license
<http://purl.org/dc/terms/license> rdf:type owl:AnnotationProperty .


###  http://purl.org/dc/terms/title
<http://purl.org/dc/terms/title> rdf:type owl:AnnotationProperty .


###  http://purl.org/vocab/vann/preferredNamespacePrefix
<http://purl.org/vocab/vann/preferredNamespacePrefix> rdf:type owl:AnnotationProperty .


###  http://purl.org/vocab/vann/preferredNamespaceUri
<http://purl.org/vocab/vann/preferredNamespaceUri> rdf:type owl:AnnotationProperty .


#################################################################
#    Object Properties
#################################################################

###  https://purl.org/ontomarc/onto#recordsMeasurement
:recordsMeasurement rdf:type owl:ObjectProperty ;
                    rdfs:domain :Device ;
                    rdfs:range :Measurement ;
                    rdfs:comment "Links a device to a measurement it records."@en ;
                    rdfs:label "records measurement"@en .


#################################################################
#    Data properties
#################################################################

###  https://purl.org/ontomarc/onto#deviceCode
:deviceCode rdf:type owl:DatatypeProperty ;
            rdfs:domain :Device ;
            rdfs:range xsd:string ;
            rdfs:comment "A textual identifier for a device."@en ;
            rdfs:label "device code"@en .


###  https://purl.org/ontomarc/onto#numericValue
:numericValue rdf:type owl:DatatypeProperty ;
              rdfs:domain :Measurement ;
              rdfs:range xsd:decimal ;
              rdfs:comment "The numeric value of a measurement."@en ;
              rdfs:label "numeric value"@en .


#################################################################
#    Classes
#################################################################

###  https://purl.org/ontomarc/onto#Device
:Device rdf:type owl:Class ;
        rdfs:comment "A generic device used in this test ontology."@en ;
        rdfs:label "Device"@en .


###  https://purl.org/ontomarc/onto#Measurement
:Measurement rdf:type owl:Class ;
             rdfs:comment "A generic measurement produced by a device."@en ;
             rdfs:label "Measurement"@en .


#################################################################
#    Individuals
#################################################################

###  https://purl.org/ontomarc/onto#TestDevice01
:TestDevice01 rdf:type owl:NamedIndividual ,
                       :Device ;
              :recordsMeasurement :TestMeasurement01 ;
              :deviceCode "DEV-001" ;
              rdfs:label "Test device 01"@en .


###  https://purl.org/ontomarc/onto#TestMeasurement01
:TestMeasurement01 rdf:type owl:NamedIndividual ,
                            :Measurement ;
                   :numericValue 42.5 ;
                   rdfs:label "Test measurement 01"@en .


